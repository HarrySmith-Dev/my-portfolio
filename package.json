{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "lint": "NODE_PATH=src yarn run lint:ts && yarn run lint:css",
    "lint:ts": "tsc --noEmit --incremental && eslint 'src/' --ext .ts,.tsx,.js --max-warnings=0 --cache && prettier --check . --cache",
    "lint:css": "stylelint 'src/**/*.style.ts?(x)' --cache",
    "preview": "vite preview"
  },
  "dependencies": {
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "styled-components": "^6.1.11"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jest": "^27.1.4",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.31.10",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "stylelint": "^16.8.2",
    "stylelint-config-recommended": "^10.0.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-order": "^6.0.0",
    "stylelint-prettier": "^2.0.0",
    "stylelint-processor-styled-components": "^1.10.0",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  }
}
